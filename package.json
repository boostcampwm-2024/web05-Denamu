{
  "name": "web05-denamu",
  "version": "0.0.1",
  "private": true,
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@types/multer": "^1.4.13",
    "artillery": "^2.0.31",
    "commitizen": "^4.3.1",
    "cz-cli": "^1.0.0",
    "cz-customizable": "^7.5.4",
    "lefthook": "^1.13.6"
  },
  "scripts": {
    "prepare": "lefthook install",
    "commit": "cz",
    "stress-fe": "artillery run -o loadtest/client/fe_report.json loadtest/client/fe_loadtest.yml",
    "stress-be-client": "artillery run -o loadtest/server/api/be_client_report.json loadtest/server/api/be_client_loadtest.yml",
    "stress-be-bottleneck": "artillery run -o loadtest/server/api/be_bottleneck_report.json loadtest/server/api/be_bottleneck_loadtest.yml",
    "stress-chat-client": "artillery run -o loadtest/server/chat/chat_client_report.json loadtest/server/chat/chat_client_loadtest.yml",
    "stress-chat-bottleneck": "artillery run -o loadtest/server/chat/chat_bottleneck_report.json loadtest/server/chat/chat_bottleneck_loadtest.yml",
    "stress-fe-html": "artillery report loadtest/client/fe_report.json",
    "stress-be-client-html": "artillery report loadtest/server/api/be_client_report.json",
    "stress-be-bottleneck-html": "artillery report loadtest/server/api/be_bottleneck_report.json",
    "stress-chat-client-html": "artillery report loadtest/server/chat/chat_client_report.json",
    "stress-chat-bottleneck-html": "artillery report loadtest/server/chat/chat_bottleneck_report.json",
    "start:dev": "docker compose -f docker-compose/docker-compose.dev.yml --profile default up --build --watch",
    "start:dev:was": "docker compose -f docker-compose/docker-compose.dev.yml --profile was up --build --watch",
    "start:dev:feed": "docker compose -f docker-compose/docker-compose.dev.yml --profile feed-crawler up --build --watch",
    "start:dev:email": "docker compose -f docker-compose/docker-compose.dev.yml --profile email-worker up --build --watch",
    "start:local": "docker compose -f docker-compose/docker-compose.local.yml --profile default up --build"
  },
  "config": {
    "commitizen": {
      "path": "cz-customizable"
    }
  }
}
